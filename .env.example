# Public site URL used for canonical links in local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex public deployment URL. Required in production. If omitted locally,
# the app uses fallback data for public pages.
NEXT_PUBLIC_CONVEX_URL=

# Convex CLI deployment name for local development, if you use Convex locally.
CONVEX_DEPLOYMENT=

# Protects admin pages, review actions, and admin-only API routes.
ADMIN_SECRET=

# Optional user agent for Convex ingestion fetches.
INGESTION_USER_AGENT=VersionWatchBot/1.0 (+https://versionwatch.dev)
